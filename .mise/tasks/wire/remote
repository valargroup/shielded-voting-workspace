#!/usr/bin/env bash
#MISE description="Remove local wiring (restore remote/git references)"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
source "$DIR/repos.sh"

STATE="$(wiring_active_state "$DIR")"
wiring_load_state "$STATE"
STATE_DIR="$DIR/.wiring/states/$STATE"

printf 'State: \033[1m%s\033[0m\n' "$STATE"

# Clear skip-worktree on every tracked file (wired + locks) first.
for entry in "${WIRED[@]+"${WIRED[@]}"}" "${WIRED_LOCKS[@]+"${WIRED_LOCKS[@]}"}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    git -C "$repo_dir" update-index --no-skip-worktree "$file" 2>/dev/null || true
done

# Unique repos in WIRED, preserving declaration order.
repos_seen=()
for entry in "${WIRED[@]+"${WIRED[@]}"}"; do
    repo="${entry%%:*}"
    found=false
    for r in "${repos_seen[@]+"${repos_seen[@]}"}"; do
        [ "$r" = "$repo" ] && found=true && break
    done
    [ "$found" = false ] && repos_seen+=("$repo")
done

# Reverse each repo's patch once, then report per file.
for repo in "${repos_seen[@]+"${repos_seen[@]}"}"; do
    repo_dir="$DIR/$repo"
    patch="$STATE_DIR/$repo.patch"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    if [ ! -f "$patch" ]; then
        printf '\033[31mError: patch not found: %s\033[0m\n' "$patch"
        exit 1
    fi

    git -C "$repo_dir" apply --reverse "$patch" 2>/dev/null || true

    for entry in "${WIRED[@]+"${WIRED[@]}"}"; do
        e_repo="${entry%%:*}"
        e_file="${entry#*:}"
        if [ "$e_repo" = "$repo" ]; then
            printf '  \033[32m●\033[0m %-40s restored remote\n' "$repo/$e_file"
        fi
    done
done

# Lock files are fully regenerated by the build system, so checkout is fine.
for entry in "${WIRED_LOCKS[@]+"${WIRED_LOCKS[@]}"}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    git -C "$repo_dir" checkout -- "$file" 2>/dev/null || true
done

IOS_LOCAL_CFG="$DIR/zodl-ios/secant/Resources/voting-config-local.json"
if [ -f "$IOS_LOCAL_CFG" ]; then
    rm "$IOS_LOCAL_CFG"
    printf '  \033[32m●\033[0m %-40s removed (CDN config will be used)\n' \
        "zodl-ios/secant/Resources/voting-config-local.json"
fi

# Stash LocalPackages so Package.swift falls back to the release binary.
# Scoped to the active state so state switching can't restore a build that
# was compiled against a different state's source.
FFI_LIVE="$DIR/zcash-swift-wallet-sdk/LocalPackages"
FFI_STASH="$DIR/zcash-swift-wallet-sdk/.LocalPackages.stashed-${STATE//[^a-zA-Z0-9]/_}"
# Drop any pre-per-state stash (migration from the old single-stash layout).
LEGACY_STASH="$DIR/zcash-swift-wallet-sdk/.LocalPackages.stashed"
if [ -d "$LEGACY_STASH" ]; then
    rm -rf "$LEGACY_STASH"
fi
if [ -d "$FFI_LIVE" ]; then
    rm -rf "$FFI_STASH"
    mv "$FFI_LIVE" "$FFI_STASH"
    printf '  \033[32m●\033[0m %-40s stashed for state %s\n' \
        "zcash-swift-wallet-sdk/LocalPackages" "$STATE"
fi

echo ""
printf '\033[32mRemote wiring restored.\033[0m Dependencies point to git URLs.\n'
printf 'Run \033[1mmise run wire:local\033[0m to switch back to local paths.\n'
