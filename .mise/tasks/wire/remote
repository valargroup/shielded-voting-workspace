#!/usr/bin/env bash
#MISE description="Remove local wiring (restore remote/git references)"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
source "$DIR/.wiring/repos.sh"

for entry in "${WIRED[@]}" "${WIRED_LOCKS[@]}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    git -C "$repo_dir" update-index --no-skip-worktree "$file" 2>/dev/null || true
done

restored=0
already=0

for entry in "${WIRED[@]}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"
    patch="$DIR/.wiring/$repo.patch"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    if [ ! -f "$patch" ]; then
        printf '\033[31mError: patch not found: %s\033[0m\n' "$patch"
        exit 1
    fi

    if git -C "$repo_dir" apply --check "$patch" >/dev/null 2>&1; then
        printf '  \033[36m●\033[0m %-40s already remote\n' "$repo/$file"
        ((already++)) || true
        continue
    fi

    if git -C "$repo_dir" apply --reverse --check "$patch" >/dev/null 2>&1; then
        git -C "$repo_dir" apply --reverse "$patch"
        printf '  \033[32m●\033[0m %-40s restored remote\n' "$repo/$file"
        ((restored++)) || true
        continue
    fi

    printf '\033[31mError: %s/%s does not match local or remote wiring state.\033[0m\n' "$repo" "$file"
    echo "Resolve the file manually, then re-run wire:remote."
    exit 1
done

# Lock files are fully regenerated by the build system, so checkout is fine.
for entry in "${WIRED_LOCKS[@]}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    git -C "$repo_dir" checkout -- "$file" 2>/dev/null || true
done

echo ""
if [ "$restored" -gt 0 ]; then
    printf '\033[32mRemote wiring restored.\033[0m (%d reverted, %d already remote)\n' "$restored" "$already"
else
    printf '\033[36mAll files already wired remote.\033[0m\n'
fi
printf 'Run \033[1mmise run wire:local\033[0m to switch back to local paths.\n'
