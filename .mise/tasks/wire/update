#!/usr/bin/env bash
#MISE description="Regenerate wiring patches from current working tree"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
source "$DIR/repos.sh"

STATE="$(wiring_active_state "$DIR")"
wiring_load_state "$STATE"
STATE_DIR="$DIR/.wiring/states/$STATE"

printf 'State: \033[1m%s\033[0m\n' "$STATE"

mkdir -p "$STATE_DIR"

# Require at least one wired file so we don't capture "just remote state" by mistake.
any_wired=false
for entry in "${WIRED[@]+"${WIRED[@]}"}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"
    if [ -d "$repo_dir/.git" ]; then
        flags=$(git -C "$repo_dir" ls-files -v -- "$file" 2>/dev/null)
        if [[ "$flags" == S* ]]; then
            any_wired=true
            break
        fi
    fi
done

if [ "$any_wired" = false ]; then
    printf '\033[31mError: local wiring is not applied.\033[0m\n'
    echo "Apply local wiring first (mise run wire:local), make your changes,"
    echo "then re-run this to capture the updated patches."
    exit 1
fi

# Unique repos in WIRED, preserving declaration order.
repos_seen=()
for entry in "${WIRED[@]+"${WIRED[@]}"}"; do
    repo="${entry%%:*}"
    found=false
    for r in "${repos_seen[@]+"${repos_seen[@]}"}"; do
        [ "$r" = "$repo" ] && found=true && break
    done
    [ "$found" = false ] && repos_seen+=("$repo")
done

updated=0

for repo in "${repos_seen[@]+"${repos_seen[@]}"}"; do
    repo_dir="$DIR/$repo"
    patch="$STATE_DIR/$repo.patch"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    # Collect this repo's files and temporarily clear skip-worktree on any that have it
    # so the diff sees the working-tree version.
    files=()
    restored=()
    for entry in "${WIRED[@]+"${WIRED[@]}"}"; do
        e_repo="${entry%%:*}"
        e_file="${entry#*:}"
        if [ "$e_repo" = "$repo" ]; then
            files+=("$e_file")
            flags=$(git -C "$repo_dir" ls-files -v -- "$e_file" 2>/dev/null)
            if [[ "$flags" == S* ]]; then
                restored+=("$e_file")
                git -C "$repo_dir" update-index --no-skip-worktree "$e_file" 2>/dev/null || true
            fi
        fi
    done

    diff_output=$(git -C "$repo_dir" diff -- "${files[@]}" 2>/dev/null || true)

    for f in "${restored[@]+"${restored[@]}"}"; do
        git -C "$repo_dir" update-index --skip-worktree "$f" 2>/dev/null || true
    done

    if [ -n "$diff_output" ]; then
        echo "$diff_output" > "$patch"
        lines=$(echo "$diff_output" | wc -l | tr -d ' ')
        printf '  \033[32m✓\033[0m %-35s %s (%s lines)\n' "$repo" "$(basename "$patch")" "$lines"
        ((updated++)) || true
    else
        printf '  \033[36m●\033[0m %-35s no diff (files match committed)\n' "$repo"
    fi
done

echo ""
if [ "$updated" -gt 0 ]; then
    printf '\033[32m%d patch(es) updated.\033[0m Remember to commit the patch files.\n' "$updated"
else
    printf 'No patches changed.\n'
fi
