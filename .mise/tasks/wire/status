#!/usr/bin/env bash
#MISE description="Show current wiring state (local vs remote)"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
source "$DIR/.wiring/repos.sh"

printf '\033[1mWiring status\033[0m\n'
printf '═════════════\n\n'

local_count=0
remote_count=0
modified_count=0
missing=0

for entry in "${WIRED[@]}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"
    patch="$DIR/.wiring/$repo.patch"

    if [ ! -d "$repo_dir/.git" ]; then
        printf '  \033[31m○\033[0m %-40s \033[31mnot a git repo\033[0m\n' "$repo/$file"
        ((missing++)) || true
        continue
    fi

    if [ ! -f "$patch" ]; then
        printf '  \033[31m○\033[0m %-40s \033[31mmissing patch\033[0m\n' "$repo/$file"
        ((modified_count++)) || true
        continue
    fi

    if git -C "$repo_dir" apply --reverse --check "$patch" >/dev/null 2>&1; then
        printf '  \033[36m●\033[0m %-40s \033[36mlocal\033[0m\n' "$repo/$file"
        ((local_count++)) || true
    elif git -C "$repo_dir" apply --check "$patch" >/dev/null 2>&1; then
        printf '  \033[32m●\033[0m %-40s \033[32mremote\033[0m\n' "$repo/$file"
        ((remote_count++)) || true
    else
        printf '  \033[33m●\033[0m %-40s \033[33mmodified\033[0m\n' "$repo/$file"
        ((modified_count++)) || true
    fi
done

echo ""
if [ "$modified_count" -gt 0 ]; then
    printf '  \033[33mInconsistent state!\033[0m Resolve modified wired files, then rerun wire:local or wire:remote.\n'
elif [ "$local_count" -gt 0 ] && [ "$remote_count" -gt 0 ]; then
    printf '  \033[33mMixed state!\033[0m Run wire:local or wire:remote to normalize.\n'
elif [ "$local_count" -gt 0 ]; then
    printf '  All files wired for \033[36mlocal development\033[0m.\n'
else
    printf '  All files wired for \033[32mremote/fork\033[0m references.\n'
fi
