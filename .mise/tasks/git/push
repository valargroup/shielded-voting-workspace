#!/usr/bin/env bash
#MISE description="Push all repos that have unpushed commits"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
source "$DIR/repos.sh"
source "$DIR/.wiring/repos.sh"

wired_repos=()
unknown_repos=()
for entry in "${WIRED[@]}"; do
    repo="${entry%%:*}"
    file="${entry#*:}"
    repo_dir="$DIR/$repo"
    patch="$DIR/.wiring/$repo.patch"
    if [ -d "$repo_dir/.git" ]; then
        if git -C "$repo_dir" apply --reverse --check "$patch" >/dev/null 2>&1; then
            wired_repos+=("$repo")
        elif ! git -C "$repo_dir" apply --check "$patch" >/dev/null 2>&1; then
            unknown_repos+=("$repo")
        fi
    fi
done

if [ ${#wired_repos[@]} -gt 0 ]; then
    printf '\033[31mRefusing to push — repos wired local:\033[0m\n'
    for r in "${wired_repos[@]}"; do
        printf '  \033[33m●\033[0m %s\n' "$r"
    done
    printf '\nRun \033[1mmise run wire:remote\033[0m first.\n'
    exit 1
fi

if [ ${#unknown_repos[@]} -gt 0 ]; then
    printf '\033[31mRefusing to push — repos in inconsistent wiring state:\033[0m\n'
    for r in "${unknown_repos[@]}"; do
        printf '  \033[33m●\033[0m %s\n' "$r"
    done
    printf '\nResolve the wired file diffs, then rerun \033[1mmise run wire:status\033[0m.\n'
    exit 1
fi

pushed=0

for entry in "${REPOS[@]}"; do
    IFS='|' read -r dir url branch <<< "$entry"
    repo_dir="$DIR/$dir"

    if [ ! -d "$repo_dir/.git" ]; then
        continue
    fi

    current=$(git -C "$repo_dir" rev-parse --abbrev-ref HEAD 2>/dev/null)
    if [ "$current" = "HEAD" ] || [ -z "$current" ]; then
        continue
    fi

    ahead=$(git -C "$repo_dir" rev-list --count "@{upstream}..HEAD" 2>/dev/null || echo "new")
    if [ "$ahead" = "0" ]; then
        continue
    fi

    printf '  \033[32m↑\033[0m %-35s %s (%s ahead)\n' "$dir" "$current" "$ahead"
    git -C "$repo_dir" push -u origin "$current"
    ((pushed++)) || true
done

echo ""
if [ "$pushed" -gt 0 ]; then
    printf '\033[32mPushed %d repo(s).\033[0m\n' "$pushed"
else
    printf 'Nothing to push.\n'
fi
