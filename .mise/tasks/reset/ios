#!/usr/bin/env bash
#MISE description="Reset Xcode/SwiftPM state for zodl-ios when package resolution wedges"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PROJECT="$DIR/zodl-ios/secant.xcodeproj"

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
cyan()  { printf '\033[36m%s\033[0m\n' "$*"; }
bold()  { printf '\033[1m%s\033[0m\n' "$*"; }

if [ ! -d "$PROJECT" ]; then
    red "Error: $PROJECT not found. Run: mise run git:sync"
    exit 1
fi

# ── Refuse to run while Xcode is open ─────────────────────────────
# Xcode rewrites these caches as it runs, so wiping them under a live
# process leaves the project in an even worse state.
if pgrep -xq Xcode; then
    red "Xcode is running. Quit it first (Cmd-Q) and rerun this task."
    exit 1
fi

bold "Resetting iOS build/package caches"
echo

# ── 1. Project-specific DerivedData ───────────────────────────────
DD_DIR="$HOME/Library/Developer/Xcode/DerivedData"
shopt -s nullglob
secant_dd=("$DD_DIR"/secant-*)
shopt -u nullglob
if [ ${#secant_dd[@]} -gt 0 ]; then
    cyan "Deleting DerivedData (${#secant_dd[@]} dir):"
    for d in "${secant_dd[@]}"; do
        echo "  - $(basename "$d")"
        rm -rf "$d"
    done
else
    echo "DerivedData: nothing to clean."
fi

# ── 2. SwiftPM artifact cache ─────────────────────────────────────
# This is the cache most Xcode reset workflows miss. Stale or
# half-extracted xcframework artifacts here cause "binary target X
# could not be mapped to an artifact with expected name X" errors,
# which cascade into every package showing as missing.
SPM_ARTIFACTS="$HOME/Library/Caches/org.swift.swiftpm/artifacts"
if [ -d "$SPM_ARTIFACTS" ]; then
    cyan "Deleting SwiftPM artifact cache:"
    echo "  - $SPM_ARTIFACTS"
    rm -rf "$SPM_ARTIFACTS"
else
    echo "SwiftPM artifact cache: nothing to clean."
fi

echo

# ── 3. Pre-warm into the default DerivedData ──────────────────────
# Resolving without -derivedDataPath populates the same DerivedData
# Xcode's GUI uses, so when Xcode reopens the artifacts are already
# extracted and indexing/resolution doesn't restart from zero.
cyan "Resolving Swift packages (default DerivedData)…"
(cd "$DIR/zodl-ios" && xcodebuild -project secant.xcodeproj -resolvePackageDependencies >/dev/null)
green "Packages resolved."

echo
bold "Next steps"
echo "  1. Open Xcode:        open $PROJECT"
echo "  2. Wait for indexing  (status bar) to fully finish before clicking anything."
echo "  3. Do NOT click 'Reset Package Caches' mid-resolution — that's how"
echo "     the cache gets wedged in the first place."
