#!/usr/bin/env bash
#MISE description="Stop local HTTPS voting config proxy"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_DIR="$DIR/.pids"
PID_FILE="$PID_DIR/config.pid"
PORT="${SVOTE_CONFIG_PORT:-8443}"

pid_alive() {
    lsof -p "$1" >/dev/null 2>&1
}

stop_pid() {
    local pid="$1"
    kill "$pid" 2>/dev/null || true
    for _ in $(seq 1 20); do
        pid_alive "$pid" || return 0
        sleep 0.25
    done
    kill -KILL "$pid" 2>/dev/null || true
}

PID=""
if [ -f "$PID_FILE" ] && pid_alive "$(cat "$PID_FILE")"; then
    PID="$(cat "$PID_FILE")"
fi
if [ -z "$PID" ]; then
    PID="$(lsof -tnP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null | head -1 || true)"
fi

if [ -n "$PID" ]; then
    stop_pid "$PID"
    printf '\033[32mStopped config proxy\033[0m pid %s\n' "$PID"
else
    echo "No config proxy found."
fi

PORT_PID="$(lsof -tnP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null | head -1 || true)"
if [ -n "$PORT_PID" ] && [ "$PORT_PID" != "$PID" ]; then
    stop_pid "$PORT_PID"
    printf '\033[32mStopped config listener\033[0m pid %s\n' "$PORT_PID"
fi

rm -f "$PID_FILE"
