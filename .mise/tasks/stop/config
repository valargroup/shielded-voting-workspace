#!/usr/bin/env bash
#MISE description="Stop local HTTPS voting config proxy"
#MISE quiet=true
set -euo pipefail

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_DIR="$DIR/.pids"
PID_FILE="$PID_DIR/config.pid"
PORT="${SVOTE_CONFIG_PORT:-8443}"
LOG_FILE="$DIR/config-server.log"

port_listener_pids() {
    lsof -tnP -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null | sort -u || true
}

pid_alive() {
    lsof -p "$1" >/dev/null 2>&1
}

stop_pid() {
    local pid="$1"
    kill "$pid" 2>/dev/null || true
    for _ in $(seq 1 20); do
        pid_alive "$pid" || return 0
        sleep 0.25
    done
    kill -KILL "$pid" 2>/dev/null || true
    for _ in $(seq 1 20); do
        pid_alive "$pid" || return 0
        sleep 0.25
    done
    return 1
}

pid_is_config_proxy() {
    local pid="$1"

    lsof -nP -a -p "$pid" 2>/dev/null |
        awk -v dir="$DIR" -v log_file="$LOG_FILE" '
            $1 == "caddy" && $4 == "cwd" && $NF == dir { cwd_seen = 1 }
            $1 == "caddy" && $NF == log_file { log_seen = 1 }
            END { exit !(cwd_seen && log_seen) }
        '
}

PIDS=""
TRACKED_PID=""
[ -f "$PID_FILE" ] && TRACKED_PID="$(cat "$PID_FILE")"
if [ -n "$TRACKED_PID" ] && pid_alive "$TRACKED_PID" && pid_is_config_proxy "$TRACKED_PID"; then
    PIDS="$PIDS $TRACKED_PID"
fi

while read -r PORT_PID; do
    [ -n "$PORT_PID" ] || continue
    if pid_is_config_proxy "$PORT_PID"; then
        case " $PIDS " in
            *" $PORT_PID "*) ;;
            *) PIDS="$PIDS $PORT_PID" ;;
        esac
    else
        printf '\033[33mLeaving non-workspace listener on port %s running:\033[0m pid %s\n' "$PORT" "$PORT_PID"
    fi
done <<< "$(port_listener_pids)"

if [ -n "$PIDS" ]; then
    for PID in $PIDS; do
        if ! stop_pid "$PID"; then
            printf '\033[31mFailed to stop config proxy pid %s\033[0m\n' "$PID"
            exit 1
        fi
        printf '\033[32mStopped config proxy\033[0m pid %s\n' "$PID"
    done
else
    echo "No config proxy found."
fi

rm -f "$PID_FILE"
