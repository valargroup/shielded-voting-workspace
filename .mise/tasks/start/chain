#!/usr/bin/env bash
#MISE description="Build + init + start single-validator chain"
#MISE quiet=true
set -e

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
export SVOTED_HOME="$DIR/.svoted"
export PATH="$HOME/go/bin:$PATH"

write_ios_config() {
    local cfg="$DIR/zodl-ios/secant/Resources/voting-config-local.json"
    if [ -d "$DIR/zodl-ios/secant/Resources" ]; then
        local host
        host="$(scutil --get LocalHostName).local"
        cat > "$cfg" <<EOFJSON
{
  "version": 1,
  "vote_servers": [{ "url": "http://${host}:1318", "label": "Local" }],
  "pir_servers": [{ "url": "http://${host}:3000", "label": "Local" }]
}
EOFJSON
        printf '\033[32miOS config → voting-config-local.json (%s)\033[0m\n' "$host"
    fi
}

PID_DIR="$DIR/.pids"
mkdir -p "$PID_DIR"
if [ -f "$PID_DIR/chain.pid" ] && kill -0 "$(cat "$PID_DIR/chain.pid")" 2>/dev/null; then
    printf '\033[33mAlready running: svoted\033[0m\n'
    write_ios_config
    exit 0
fi

# ── Ensure vote-sdk .env with VM_PRIVKEY ─────────────────────────
ENV_FILE="$DIR/vote-sdk/.env"
if [ ! -f "$ENV_FILE" ]; then
    if [ -f "$DIR/vote-sdk/.env.example" ]; then
        cp "$DIR/vote-sdk/.env.example" "$ENV_FILE"
        printf '\033[32mCreated vote-sdk/.env from .env.example\033[0m\n'
    else
        touch "$ENV_FILE"
    fi
fi
# Fill in VM_PRIVKEY if missing or empty.
EXISTING_KEY=$(grep '^VM_PRIVKEY=' "$ENV_FILE" 2>/dev/null | cut -d= -f2)
if [ -z "$EXISTING_KEY" ]; then
    KEY=$(openssl rand -hex 32)
    if grep -q '^VM_PRIVKEY=' "$ENV_FILE"; then
        sed -i.bak "s/^VM_PRIVKEY=.*/VM_PRIVKEY=$KEY/" "$ENV_FILE"
        rm -f "$ENV_FILE.bak"
    else
        echo "VM_PRIVKEY=$KEY" >> "$ENV_FILE"
    fi
    printf '\033[32mGenerated VM_PRIVKEY in vote-sdk/.env\033[0m\n'
fi

# ── Build + init ─────────────────────────────────────────────────
make -C "$DIR/vote-sdk" init

# ── Start svoted ─────────────────────────────────────────────────
SVOTE_PIR_URL=${SVOTE_PIR_URL:-http://localhost:3000} \
SVOTE_LWD_URLS=${SVOTE_LWD_URLS:-https://zec.rocks:443} \
make -C "$DIR/vote-sdk" start > "$DIR/svoted.log" 2>&1 &
echo $! > "$PID_DIR/chain.pid"
printf '\033[32mStarted svoted → svoted.log\033[0m\n'

# ── Wait for chain readiness ────────────────────────────────────
printf 'Waiting for chain to be ready...'
for i in $(seq 1 60); do
    if svoted status --home "$SVOTED_HOME" 2>/dev/null | grep -q latest_block_height; then
        printf ' \033[32mready\033[0m\n'
        break
    fi
    if [ "$i" -eq 60 ]; then
        printf ' \033[31mTIMEOUT\033[0m\n'
        tail -50 "$DIR/svoted.log"
        exit 1
    fi
    printf '.'
    sleep 2
done

# ── Wait for helper server ──────────────────────────────────────
printf 'Waiting for helper server...'
for i in $(seq 1 15); do
    if curl -sf http://localhost:1318/api/v1/status > /dev/null 2>&1; then
        printf ' \033[32mready\033[0m\n'
        break
    fi
    printf '.'
    sleep 1
done

# ── Register Pallas key ─────────────────────────────────────────
printf 'Registering Pallas key...'
for i in $(seq 1 10); do
    if svoted tx vote register-pallas-key \
        --from validator --chain-id svote-1 --keyring-backend test \
        --home "$SVOTED_HOME" -y > /dev/null 2>&1; then
        printf ' \033[32m✓\033[0m\n'
        break
    fi
    if [ "$i" = "10" ]; then
        printf ' \033[31mFAILED\033[0m\n'
        exit 1
    fi
    printf '.'
    sleep 2
done

# ── Write iOS local config ──────────────────────────────────────
write_ios_config
