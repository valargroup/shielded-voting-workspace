#!/usr/bin/env bash
#MISE description="Build xcframework for simulator + open Xcode"
#MISE quiet=true
set -e

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
SDK_DIR="$DIR/zcash-swift-wallet-sdk"

if [ ! -d "$SDK_DIR/.git" ]; then
    printf '\033[31mError: zcash-swift-wallet-sdk not cloned. Run: mise run git:sync\033[0m\n'
    exit 1
fi

# ── Ensure LocalPackages exists ──────────────────────────────────
if [ ! -d "$SDK_DIR/LocalPackages" ]; then
    printf '\033[36mInitializing LocalPackages (first time only)...\033[0m\n'
    # Create the SPM wrapper — rebuild-local-ffi.sh will populate the xcframework
    # Create both dirs — rebuild-local-ffi.sh guards on xcframework dir existence
    mkdir -p "$SDK_DIR/LocalPackages/libzcashlc.xcframework"
    cat > "$SDK_DIR/LocalPackages/Package.swift" << 'EOF'
// swift-tools-version:5.6
import PackageDescription

let package = Package(
    name: "libzcashlc",
    products: [
        .library(name: "libzcashlc", targets: ["libzcashlc"])
    ],
    targets: [
        .binaryTarget(
            name: "libzcashlc",
            path: "libzcashlc.xcframework"
        )
    ]
)
EOF
fi

# ── Build Rust for iOS Simulator (skip if up to date) ────────────
BUILT_LIB="$SDK_DIR/target/aarch64-apple-ios-sim/release/libzcashlc.a"
XCFW_LIB="$SDK_DIR/LocalPackages/libzcashlc.xcframework/ios-arm64_x86_64-simulator/libzcashlc.framework/libzcashlc"

needs_build=true
if [ -f "$XCFW_LIB" ] && [ -f "$BUILT_LIB" ]; then
    # Skip if xcframework copy is newer than (or same as) the cargo output
    if [ ! "$BUILT_LIB" -nt "$XCFW_LIB" ]; then
        # Also check if any Rust source is newer than the built lib
        newer_src=$(find "$SDK_DIR/rust/src" "$DIR/librustvoting" "$DIR/librustzcash" "$DIR/voting-circuits" \
            -name '*.rs' -newer "$BUILT_LIB" 2>/dev/null | head -1)
        if [ -z "$newer_src" ]; then
            needs_build=false
        fi
    fi
fi

if [ "$needs_build" = true ]; then
    printf '\033[36mBuilding Rust FFI for iOS Simulator...\033[0m\n'
    "$SDK_DIR/Scripts/rebuild-local-ffi.sh" ios-sim
else
    printf '\033[32mxcframework is up to date, skipping Rust build.\033[0m\n'
fi

# ── Open Xcode ──────────────────────────────────────────────────
PROJECT="$DIR/zodl-ios/secant.xcodeproj"
if [ -d "$PROJECT" ]; then
    printf '\033[32mOpening zodl-ios in Xcode...\033[0m\n'
    open "$PROJECT"
    echo ""
    echo "Xcode is ready. Use Cmd+R to build and run on the simulator."
    echo "After Rust changes, re-run: mise run start:ios"
else
    printf '\033[33mzodl-ios project not found. Opening SDK instead.\033[0m\n'
    open "$SDK_DIR"
fi
