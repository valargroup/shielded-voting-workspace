#!/usr/bin/env bash
#MISE description="Start nullifier PIR server"
#MISE quiet=true
set -e

DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PID_DIR="$DIR/.pids"
PID_FILE="$PID_DIR/nf.pid"
PORT="${SVOTE_PIR_PORT:-${PORT:-3000}}"
NF_DIR="$DIR/vote-nullifier-pir"
PIR_DATA_DIR="$NF_DIR/pir-data"
NF_BIN="$NF_DIR/target/release/nf-server"
mkdir -p "$PID_DIR"

health_status() {
    python3 -c 'import json,sys; print(json.load(sys.stdin).get("status","unknown"))' 2>/dev/null || echo "unknown"
}

has_prestaged_pir_data() {
    [ -s "$PIR_DATA_DIR/pir_root.json" ] &&
        [ -s "$PIR_DATA_DIR/tier0.bin" ] &&
        [ -s "$PIR_DATA_DIR/tier1.bin" ] &&
        [ -s "$PIR_DATA_DIR/tier2.bin" ]
}

# Truth source is the port, not the PID file — survive orphaned processes
# from previous runs and writes the actual nf-server PID (not make's).
LISTENING_PID=$(lsof -tnP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | head -1 || true)

if [ -n "$LISTENING_PID" ]; then
    if HEALTH=$(curl -sf "http://localhost:$PORT/health" 2>/dev/null); then
        STATUS=$(printf '%s' "$HEALTH" | health_status)
        if [ "$STATUS" = "error" ]; then
            printf '\033[31mPort %s held by nf-server pid %s, but health status is error.\033[0m\n' "$PORT" "$LISTENING_PID"
            exit 1
        fi
        echo "$LISTENING_PID" > "$PID_FILE"
        printf '\033[33mAlready listening: nf-server (pid %s, health=%s)\033[0m\n' "$LISTENING_PID" "$STATUS"
        exit 0
    fi
    printf '\033[31mPort %s held by pid %s but /health not responding.\033[0m\n' "$PORT" "$LISTENING_PID"
    printf 'Investigate or kill it manually: kill %s\n' "$LISTENING_PID"
    exit 1
fi

# Stale tracking — clean up before we start fresh.
rm -f "$PID_FILE"

case "${SVOTE_PIR_START_SYNC:-}" in
    1|true|TRUE|yes|YES)
        make -C "$NF_DIR" sync
        ;;
    *)
        echo "Skipping local nullifier sync/export."
        echo "Set SVOTE_PIR_START_SYNC=1 to rebuild local pir-data before serving."
        ;;
esac

if [ "${SVOTE_PIR_VOTING_CONFIG_URL+x}" != "x" ]; then
    if has_prestaged_pir_data; then
        export SVOTE_PIR_VOTING_CONFIG_URL=""
        echo "Using pre-staged pir-data; startup CDN bootstrap disabled."
        echo "Set SVOTE_PIR_VOTING_CONFIG_URL=... to force bootstrap discovery."
    else
        echo "No pre-staged pir-data found; nf-server will use its bootstrap defaults."
    fi
elif [ -z "$SVOTE_PIR_VOTING_CONFIG_URL" ]; then
    echo "SVOTE_PIR_VOTING_CONFIG_URL is empty; using pre-staged pir-data only."
else
    echo "Using SVOTE_PIR_VOTING_CONFIG_URL=$SVOTE_PIR_VOTING_CONFIG_URL"
fi

cd "$NF_DIR" && cargo build -p nf-server --release --features serve

"$NF_BIN" serve --pir-data-dir "$PIR_DATA_DIR" --port "$PORT" > "$DIR/nf-serve.log" 2>&1 &
NF_PID=$!

printf 'Waiting for nf-server to bind :%s...' "$PORT"
for i in $(seq 1 30); do
    SERVER_PID=$(lsof -tnP -iTCP:$PORT -sTCP:LISTEN 2>/dev/null | head -1 || true)
    if [ -n "$SERVER_PID" ]; then
        if HEALTH=$(curl -sf "http://localhost:$PORT/health" 2>/dev/null); then
            STATUS=$(printf '%s' "$HEALTH" | health_status)
            if [ "$STATUS" = "error" ]; then
                printf ' \033[31mhealth=error\033[0m\n'
                tail -20 "$DIR/nf-serve.log"
                exit 1
            fi
            echo "$SERVER_PID" > "$PID_FILE"
            printf ' \033[32mstarted (pid %s, health=%s)\033[0m → nf-serve.log\n' "$SERVER_PID" "$STATUS"
            exit 0
        fi
    fi
    if ! kill -0 "$NF_PID" 2>/dev/null; then
        printf ' \033[31mnf-server exited before bind\033[0m\n'
        tail -20 "$DIR/nf-serve.log"
        exit 1
    fi
    printf '.'
    sleep 1
done
printf ' \033[31mTIMEOUT\033[0m\n'
tail -20 "$DIR/nf-serve.log"
exit 1
