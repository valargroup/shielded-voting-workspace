#!/usr/bin/env bash
#MISE description="Tail merged logs from svoted, nf-server, and config proxy"
#MISE quiet=true

DIR="$(cd "$(dirname "$0")/../.." && pwd)"

touch "$DIR/svoted.log" "$DIR/nf-serve.log" "$DIR/config-server.log"

tail -f "$DIR/svoted.log" "$DIR/nf-serve.log" "$DIR/config-server.log" | sed \
    -e "s|^==> $DIR/svoted.log <==|\x1b[36m[svoted]\x1b[0m|" \
    -e "s|^==> $DIR/nf-serve.log <==|\x1b[33m[nf-server]\x1b[0m|" \
    -e "s|^==> $DIR/config-server.log <==|\x1b[35m[config]\x1b[0m|"
