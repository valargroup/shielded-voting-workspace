 incrementalmerkletree = { version = "0.8", default-features = false }
 
@@ -98,15 +99,33 @@ crate-type = ["staticlib"]
 [profile.release]
 lto = true
 
+# Local overrides: sibling repos as relative paths.
 [patch.crates-io]
-pczt = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-orchard = { package = "orchard", git = "https://github.com/zcash/orchard.git", rev = "6b12c77260aa7fac0d804983fc31b71b584d48e0" }
-sapling = { package = "sapling-crypto", git = "https://github.com/zcash/sapling-crypto.git", rev = "4f95c2286dbe90f05e6f44d634bc2924b992fab4" }
-transparent = { package = "zcash_transparent", git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_address = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_client_backend = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_client_sqlite = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_keys = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_primitives = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_proofs = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
-zcash_protocol = { git = "https://github.com/zcash/librustzcash.git", rev = "438657c52c7b5abd933c715e83f0289a79349c5a" }
+pczt = { path = "../librustzcash/pczt" }
+valar-orchard = { path = "../voting-circuits/orchard" }
+voting-circuits = { path = "../voting-circuits/voting-circuits" }
+zcash_transparent = { path = "../librustzcash/zcash_transparent" }
+zcash_address = { path = "../librustzcash/components/zcash_address" }
+zcash_encoding = { path = "../librustzcash/components/zcash_encoding" }
+zcash_client_backend = { path = "../librustzcash/zcash_client_backend" }
+zcash_client_sqlite = { path = "../librustzcash/zcash_client_sqlite" }
+zcash_keys = { path = "../librustzcash/zcash_keys" }
+zcash_primitives = { path = "../librustzcash/zcash_primitives" }
+zcash_proofs = { path = "../librustzcash/zcash_proofs" }
+zcash_protocol = { path = "../librustzcash/components/zcash_protocol" }
+# Mirror librustzcash's own sapling-crypto patch. Required because Cargo
+# only honours `[patch]` in the root workspace, so librustzcash's workspace
+# patch is ignored when it is consumed via path. Without this, sapling-crypto
+# resolves to crates.io 0.6.2 (where `pczt::Bundle::extract` consumes `self`),
+# and librustzcash's `tx_extractor` — which calls `extract` on `&Bundle` —
+# fails to compile.
+sapling = { package = "sapling-crypto", git = "https://github.com/zcash/sapling-crypto.git", rev = "b8a81c22f034d68f9bbd6cba728aab807b9ba2ea" }
+
+[patch."https://github.com/valargroup/librustzcash"]
+pczt = { path = "../librustzcash/pczt" }
+zcash_keys = { path = "../librustzcash/zcash_keys" }
+zcash_primitives = { path = "../librustzcash/zcash_primitives" }
+zcash_protocol = { path = "../librustzcash/components/zcash_protocol" }
+
+[patch."https://github.com/valargroup/voting-circuits.git"]
+voting-circuits = { path = "../voting-circuits/voting-circuits" }
